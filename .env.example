# Copy to `.env`. The companion uses bring-your-own-key cloud APIs so everything runs on a laptop
# with no GPU. You need ONE generation key and ONE embedding key (Anthropic has no embeddings API).
# See docs/PROVIDER-SWAP.md. Qdrant runs locally via Docker — no key.

# --- Default stack: Claude (generation) + OpenAI (embeddings) -----------------
ANTHROPIC_API_KEY=        # generation + LLM reranking (claude-opus-4-8)
OPENAI_API_KEY=           # embeddings (text-embedding-3-large) — and GPT generation if you swap

# --- Local services ----------------------------------------------------------
QDRANT_URL=http://localhost:6333

# --- Provider selection (override the defaults without editing code) ----------
# GEN_PROVIDER=anthropic     # anthropic (default, claude-opus-4-8) | openai
# EMBED_PROVIDER=openai      # openai (default, text-embedding-3-large) | voyage
# RERANK_PROVIDER=llm        # llm (default, reuses the generation provider) | cohere

# --- Optional alternative providers ------------------------------------------
# VOYAGE_API_KEY=           # alternative embeddings
# COHERE_API_KEY=           # alternative reranker (Cohere Rerank)

# Single-key option: set GEN_PROVIDER=openai and EMBED_PROVIDER=openai to run everything
# on one OPENAI_API_KEY (GPT generation + text-embedding-3 embeddings).
