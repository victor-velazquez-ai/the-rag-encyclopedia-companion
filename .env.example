# Copy to `.env`. The DEFAULT stack needs NOTHING here — it runs all-open and local.
# These variables only activate the optional managed-provider swaps (see docs/PROVIDER-SWAP.md).

# --- Local stack (defaults; change only if you moved the services) -----------
QDRANT_URL=http://localhost:6333

# --- Provider selection (default = all-open, self-host) ----------------------
# Override per-component in configs/*.yaml, or globally here.
# EMBED_PROVIDER=qwen3        # qwen3 (default) | voyage | gemini
# RERANK_PROVIDER=jina        # jina (default)  | cohere
# GEN_PROVIDER=vllm           # vllm (default)  | openai-compatible

# --- Optional managed API keys (only if you select a managed provider) -------
# VOYAGE_API_KEY=
# GEMINI_API_KEY=
# COHERE_API_KEY=
# OPENAI_API_KEY=             # any OpenAI-compatible generator endpoint
# OPENAI_BASE_URL=
